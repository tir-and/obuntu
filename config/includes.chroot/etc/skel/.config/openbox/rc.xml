<?xml version="1.0" encoding="UTF-8"?>
<openbox_config>
  <keyboard>
    <keybind key="W-Enter"><action name="Execute"><command>alacritty</command></action></keybind>
    <keybind key="Print"><action name="Execute"><command>flameshot gui</command></action></keybind>
    <keybind key="W-T"><action name="Execute"><command>tilda</command></action></keybind>
    <keybind key="W-R"><action name="Execute"><command>rofi -show drun</command></action></keybind>
  </keyboard>
  <!-- Tweak focus, margins, theme later -->
</openbox_config>
