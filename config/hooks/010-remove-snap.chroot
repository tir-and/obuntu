#!/bin/bash
set -e
# Purge snap & noise
apt-get purge -y snapd apport whoopsie cloud-init
rm -rf /snap /var/snap /var/lib/snapd /var/cache/snapd /home/*/snap
# Prevent future install by pinning (optional)
cat >/etc/apt/preferences.d/99-nosnap<<'EOF'
Package: snapd
Pin: release *
Pin-Priority: -10
EOF
