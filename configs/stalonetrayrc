# Stalonetray - dropdown tray
background "#000000"
decorations none
dockapp_mode simple
fuzzy_edges 0
grow_gravity NW
icon_gravity NW
geometry 24x1+8+36
# 24x1 = width x height in icon units; tweak for density
icon_size 20
slot_size 22
skip_taskbar true
sticky true
transparent true
window_type dock
