# ---- Environment ----
export GTK_THEME=Celestial:dark

# ---- X settings (GTK theme, fonts, icons) ----
xsettingsd &

# ---- Compositor & notifications ----
picom --config "$HOME/.config/picom/picom.conf" &
dunst &

# ---- Network & (optional) Bluetooth applets ----
nm-applet &
# blueman-applet &   # uncomment if you install blueman

# ---- Dock ----
plank &   # or plank-reloaded; config path is the same

# ---- System tray: start, then hide; toggle via ~/.local/bin/system_tray.sh ----
stalonetray -c "$HOME/.config/stalonetrayrc" &
(sleep 0.7; xdotool search --name stalonetray windowunmap) &

# ---- Eww vertical bar ----
command -v eww >/dev/null 2>&1 && "$HOME/.config/eww/obuntu/start.sh" &


# ---- Wallpaper (optional) ----
if [ -f /usr/share/backgrounds/obuntu.png ]; then
  feh --bg-scale /usr/share/backgrounds/obuntu.png
fi

